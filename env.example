# Скопируйте имена переменных в Render → Environment (значения подставьте свои).
# Файл с реальными секретами не коммитьте; переименуйте в .env только локально и добавьте .env в .gitignore (уже есть).

# DaData — обязательно для /company-by-inn
DADATA_API_KEY=

# Опционально: секрет DaData для части методов clean
# DADATA_SECRET_KEY=

# REST amoCRM — для POST /integrations/amo/webhook (синхронизация сделки по ИНН)
# BASE: только URL аккаунта, без /api — например https://shabuninaleksei.amocrm.ru
AMOCRM_API_BASE=https://ВАШ_ПОДДОМЕН.amocrm.ru
# Токен: вставляйте на Render без кавычек (не "eyJ...", а eyJ...)
AMOCRM_ACCESS_TOKEN=
# ID интеграции из amo «Ключи и доступы» — в заголовок X-Client-UUID (как в amocrm-api-php); желательно задать
# AMOCRM_CLIENT_ID=263161a1-....-....

# Опционально: если задан — вебхук должен передать тот же секрет в JSON "secret" или заголовке X-Webhook-Secret
# AMO_WEBHOOK_SECRET=

# ID кастомных полей сделки (если не заданы — подставятся дефолты из main.py под ваш аккаунт)
# AMO_FIELD_INN=1303797
# Если ИНН в карточке компании, а не сделки — id поля ИНН у компании (часто другой, чем у сделки):
# AMO_FIELD_INN_COMPANY=
# AMO_FIELD_KPP=1303799
# AMO_FIELD_ADDRESS=1001617
# AMO_FIELD_BANK=1303155
# AMO_FIELD_RS=1303807
# AMO_FIELD_CORR=1303805
# AMO_FIELD_OGRN=
# AMO_FIELD_COMPANY_NAME=
# и др. см. _dadata_row_to_amo_lead_cfv в main.py

# Данные интеграции из amo («Client ID», «Client secret») — для будущего OAuth; вебхук их не требует
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
